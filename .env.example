# Public canonical URL used by metadata, sitemap and share cards.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Contact form delivery through Resend.
RESEND_API_KEY=re_your_api_key
CONTACT_EMAIL=your-inbox@example.com
CONTACT_FROM_EMAIL=Portfolio <portfolio@your-verified-domain.example>

# Optional anti-spam protection. Configure both values to enforce Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional distributed rate limit for serverless production deployments.
# Without these values, development uses a bounded in-memory fallback only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
